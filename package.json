{
  "name": "africonnect-monorepo",
  "private": true,
  "packageManager": "bun@1.3.4",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev:web": "cd apps/web && bun run dev",
    "dev:mobile": "cd apps/mobile && bun run start",
    "dev:convex": "cd packages/convex && bun run dev",
    "deploy:convex": "cd packages/convex && bun run deploy"
  },
  "ignoreScripts": ["sharp", "unrs-resolver"],
  "trustedDependencies": ["sharp", "unrs-resolver"]
}
